# Node Configuration
NODE_ENV=production
PORT=3000

# Database Configuration (Connects via proxy-net to the 'postgres' container)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=verify-full"

JWT_ACCESS_SECRET=your_jwt_access_secret_key_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me


UPSTASH_REDIS_REST_URL="https://your-upstash-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
EMAIL_FROM="My App <your_email@gmail.com>"

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
FRONTEND_URL=http://localhost:5173

# S3 File Storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=your_s3_bucket_name
# Optional: use CloudFront/custom public domain for returned file URLs
AWS_S3_PUBLIC_BASE_URL=https://cdn.example.com
# Optional: set only if your bucket policy still requires object ACLs
# AWS_S3_OBJECT_ACL=public-read
# Optional: S3-compatible storage such as MinIO/DigitalOcean Spaces
# AWS_S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
# AWS_S3_FORCE_PATH_STYLE=false

AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_primary_certificate
AGORA_TOKEN_EXPIRE_SECONDS=3600
