model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String
  title       String
  body        String?
  data        Json?
  targetUrl   String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  deliveredAt DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
