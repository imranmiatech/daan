model User {
  id                    String                    @id @default(uuid())
  fullName              String
  email                 String                    @unique
  password              String
  createdAt             DateTime                  @default(now())
  isEmailVerified       Boolean                   @default(false)
  role                  Role                      @default(STUDENT)
  updatedAt             DateTime                  @updatedAt
  refreshTokenHash      String?
  otpCode               String?
  otpExpires            DateTime?
  conversations         ConversationParticipant[]
  courses               Course[]
  courseEnrollments     CourseEnrollment[]
  courseCompletions     CourseCompletion[]
  curriculumProgress    CurriculumProgress[]
  sentMessages          Message[]
  paymentInfo           PaymentInformation?
  resources             Resource[]
  givenReviews          Review[]                  @relation("StudentReviews")
  notifications         Notification[]
  profile               UserProfile?
  payments              Payment[]
  notifyCourseUpdates   Boolean                   @default(true)
  notifyNewContent      Boolean                   @default(true)
  notifyLessonReminders Boolean                   @default(true)
  notifyNewMessages     Boolean                   @default(true)
  notifyWeeklyDigest    Boolean                   @default(false)
}
