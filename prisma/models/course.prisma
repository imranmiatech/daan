model Course {
  id                 String               @id @default(uuid())
  tutorId            String
  title              String
  category           String
  description        String
  extraInfos         String[]
  topics             String[]
  requirement        String?
  image              String?
  curriculums        String[]
  startDate          DateTime
  time               String
  timeZone           String
  classDuration      Int
  language           String
  courseDuration     Int
  pricePerStudent    Float
  minStudent         Int
  maxStudent         Int
  enrollmentDeadline DateTime
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  tutor              User                 @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  enrollments        CourseEnrollment[]
  courseCompletions  CourseCompletion[]
  curriculumProgress CurriculumProgress[]
  lessonStates       StudentLessonState[]
  curriculumItems    Curriculum[]
  payments           Payment[]
  resources          Resource[]

  @@index([tutorId])
  @@index([category])
  @@index([enrollmentDeadline])
}

model CourseEnrollment {
  id        String   @id @default(uuid())
  courseId  String
  studentId String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([studentId])
  @@index([courseId])
}

model CurriculumProgress {
  id              String   @id @default(uuid())
  courseId        String
  studentId       String
  curriculumIndex Int
  completedAt     DateTime @default(now())
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student         User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId, curriculumIndex])
  @@index([studentId])
  @@index([courseId])
}

model CourseCompletion {
  id          String   @id @default(uuid())
  courseId    String
  studentId   String
  completedAt DateTime @default(now())
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([studentId])
  @@index([courseId])
}

model Curriculum {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  date       DateTime
  time       String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}

model StudentLessonState {
  id              String   @id @default(uuid())
  courseId        String
  studentId       String
  curriculumIndex Int
  status          String
  reason          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student         User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId, curriculumIndex])
  @@index([studentId])
  @@index([courseId])
  @@index([status])
}
