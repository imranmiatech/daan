model UserProfile {
  id                String            @id @default(uuid())
  userId            String            @unique
  country           String?
  city              String?
  avatarUrl         String?
  bio               String?
  yearOfExperience  Int?
  pricePerHour      Float?
  languageExpertise String?
  aboutMe           String?
  teachingCategory  String?
  teachingSkills    String[]
  sessionDuration   Int?              @default(60)
  videoUrl          String?
  applicationStatus ApplicationStatus @default(DRAFT)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  averageRating     Float?
  totalReviews      Int               @default(0)
  availability      Availability[]
  education         Education[]
  reviews           Review[]          @relation("TutorReviews")
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Education {
  id          String      @id @default(uuid())
  profileId   String
  institution String?
  country     String?
  city        String?
  degree      String?
  passingYear Int?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  profile     UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model Availability {
  id        String      @id @default(uuid())
  profileId String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  timezone  String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  profile   UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([dayOfWeek])
}
