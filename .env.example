# Node Configuration
NODE_ENV=production
PORT=3000

# Database Configuration (Connects via proxy-net to the 'postgres' container)
DATABASE_URL=postgresql://daanclerk_user:secure_password_here@postgres:5432/daanclerk_db?schema=public

# JWT Security
JWT_ACCESS_SECRET=your_jwt_access_secret_key_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me

# Redis Configuration (if using standard Redis connection in future)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secure_redis_password_here

# Upstash Redis (if keeping Upstash configuration)
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_specific_password_here
EMAIL_FROM="App Name <your_email@gmail.com>"

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend URL
FRONTEND_URL=https://yourdomain.com
