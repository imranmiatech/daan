model Review {
  id             String   @id @default(uuid())

  // Rating: 1–5 stars
  rating         Int

  // Optional text review
  comment        String?  @db.Text

  // The student who wrote the review
  reviewerId     String
  reviewer       User        @relation("StudentReviews", fields: [reviewerId], references: [id], onDelete: Cascade)

  // The tutor's profile where the review is stored
  tutorProfileId String
  tutorProfile   UserProfile @relation("TutorReviews", fields: [tutorProfileId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // One student can only review one tutor once
  @@unique([reviewerId, tutorProfileId])
}
